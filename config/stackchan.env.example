# Copy to /etc/stackchan-remote-mcp.env and replace all CHANGE_ME values.

# Mosquitto
STACKCHAN_MQTT_BROKER=127.0.0.1
STACKCHAN_MQTT_PORT=1883
STACKCHAN_MQTT_USER=stackchan
STACKCHAN_MQTT_PASS=CHANGE_ME
STACKCHAN_MQTT_TOPIC_FACE=stackchan/face
STACKCHAN_MQTT_TOPIC_CAPTURE=stackchan/capture
STACKCHAN_MQTT_TOPIC_TOUCH=stackchan/touch
STACKCHAN_MQTT_TOPIC_REPLY=stackchan/reply
STACKCHAN_MQTT_TOUCH_CLIENT_ID=stackchan-mcp-touch-listener
STACKCHAN_MQTT_RESPONDER_CLIENT_ID=stackchan-touch-responder

# MCP
STACKCHAN_MCP_HOST=0.0.0.0
STACKCHAN_MCP_PORT=18003
STACKCHAN_TOUCH_EVENT_PATH=/var/lib/stackchan-remote-mcp/touch-events.jsonl
STACKCHAN_TOUCH_MAX_EVENTS=1000

# Photo relay
STACKCHAN_RELAY_HOST=0.0.0.0
STACKCHAN_RELAY_PORT=18090
STACKCHAN_RELAY_URL=http://127.0.0.1:18090
STACKCHAN_RELAY_TOKEN=CHANGE_ME
STACKCHAN_RELAY_SAVE_DIR=/var/lib/stackchan-remote-mcp
STACKCHAN_RELAY_MAX_BYTES=2097152

# Immediate touch response
# Keep the real API key only in /etc/stackchan-remote-mcp.env (mode 600).
STACKCHAN_MODEL_PROVIDER=siliconflow
STACKCHAN_MODEL_API_KEY=CHANGE_ME
STACKCHAN_MODEL_API_URL=https://api.siliconflow.cn/v1/chat/completions
STACKCHAN_MODEL_NAME=Qwen/Qwen3-8B
# Keep false for the shortest touch-response latency.
STACKCHAN_MODEL_ENABLE_THINKING=false
# The next two options apply only when STACKCHAN_MODEL_PROVIDER=openai.
STACKCHAN_MODEL_REASONING_EFFORT=none
STACKCHAN_MODEL_SAFETY_IDENTIFIER=stackchan-owner-CHANGE_ME
STACKCHAN_TOUCH_PERSONA_PROMPT_PATH=/etc/stackchan-touch-persona.txt
STACKCHAN_TOUCH_REPLY_HISTORY_PATH=/var/lib/stackchan-remote-mcp/touch-reply-history.json
STACKCHAN_TOUCH_REPLY_HISTORY_LIMIT=6
STACKCHAN_TOUCH_REPLY_BATCH_WINDOW_MS=350
STACKCHAN_TOUCH_REPLY_TIMEOUT_SECONDS=20
STACKCHAN_TOUCH_REPLY_MAX_CHARS=48
