# Copy to /etc/stackchan-remote-mcp.env and replace all CHANGE_ME values.

# Mosquitto
STACKCHAN_MQTT_BROKER=127.0.0.1
STACKCHAN_MQTT_PORT=1883
STACKCHAN_MQTT_USER=stackchan
STACKCHAN_MQTT_PASS=CHANGE_ME
STACKCHAN_MQTT_TOPIC_FACE=stackchan/face
STACKCHAN_MQTT_TOPIC_CAPTURE=stackchan/capture

# MCP
STACKCHAN_MCP_HOST=0.0.0.0
STACKCHAN_MCP_PORT=18003

# Photo relay
STACKCHAN_RELAY_HOST=0.0.0.0
STACKCHAN_RELAY_PORT=18090
STACKCHAN_RELAY_URL=http://127.0.0.1:18090
STACKCHAN_RELAY_TOKEN=CHANGE_ME
STACKCHAN_RELAY_SAVE_DIR=/var/lib/stackchan-remote-mcp
STACKCHAN_RELAY_MAX_BYTES=2097152
