# Insert this block inside the HTTPS `server { ... }` for your domain.
# External MCP URL: https://YOUR_DOMAIN/stackchan/mcp

location /stackchan/ {
    # FastMCP may reject the public domain Host with HTTP 421.
    # Forward the local upstream Host used by the tested setup.
    # The trailing slash is important:
    # /stackchan/mcp -> upstream /mcp
    proxy_pass http://127.0.0.1:18003/;

    proxy_http_version 1.1;
    proxy_set_header Host 127.0.0.1:18003;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection "";

    proxy_buffering off;
    proxy_read_timeout 3600s;
}
